# Razorpay Credentials
# Get these from https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Comma-separated list of valid API keys for your service
# Example: VALID_API_KEYS=key_abc123,key_def456
VALID_API_KEYS=your_secret_api_key_here

# Port for local development (Vercel ignores this)
PORT=3000
